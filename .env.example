# ==========================================
# プログラマー適性試験システム - 環境設定ファイル
# このファイルを.envにコピーして使用してください
# ※ docker compose up --build するだけで全自動セットアップされます
# ==========================================

# ====================
# アプリケーション設定
# ====================
APP_NAME=ProgrammerAptitudeTest
APP_ENV=production
# APP_KEYは初回起動時に自動生成されます
APP_KEY=
APP_DEBUG=false
# 本番環境のURLを設定してください
APP_URL=http://localhost

# ====================
# ポート設定（オプション）
# ====================
APP_PORT=80
DB_PORT=3306
REDIS_PORT=6379

# ====================
# データベース設定（デフォルト値で動作します）
# ====================
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=sail
DB_PASSWORD=password
DB_ROOT_PASSWORD=rootpassword

# ====================
# セッション設定
# ====================
SESSION_DRIVER=redis
SESSION_LIFETIME=1440
SESSION_DOMAIN=localhost
SESSION_SECURE_COOKIE=false

# ====================
# キャッシュ・Redis設定
# ====================
CACHE_STORE=redis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

# ====================
# ログ設定
# ====================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# ====================
# メール設定
# ====================
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ====================
# フロントエンド設定
# ====================
VITE_APP_NAME="${APP_NAME}"
